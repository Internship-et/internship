# ─────────────────────────────────────────────────────────────
# Staging Environment Variables — Example Template
# Copy this file to .env.stage and fill in real values.
#   cp apps/api/.env.stage.example apps/api/.env.stage
# Do NOT commit .env.stage to version control.
# ─────────────────────────────────────────────────────────────

NODE_ENV=staging
PORT=3000
DATABASE_URL=postgresql://internship:STAGE_DB_PASSWORD_HERE@localhost:5434/internship_stage
REDIS_URL=redis://localhost:6380

# JWT_SECRET must be at least 32 characters.
# Generate a strong secret:
#   openssl rand -hex 32
JWT_SECRET=change-this-to-a-64-char-hex-string-eg-openssl-rand-hex-32

CORS_ORIGINS=http://localhost:3001
LOG_LEVEL=info

# Optional: staging-specific overrides
# API_PREFIX=/api/v1
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
