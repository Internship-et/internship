# ─────────────────────────────────────────────────────────────
# Production Environment Variables — EXAMPLE ONLY
# Copy this file to .env.prod and replace all values.
# NEVER commit real secrets to version control.
# ─────────────────────────────────────────────────────────────

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# Database (Required)
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (Optional — in-memory fallback available)
REDIS_URL=redis://:password@host:6379

# JWT (Required — min 32 characters)
JWT_SECRET=replace-with-random-64-char-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (Configure for your production domain)
CORS_ORIGINS=https://app.example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Storage (Optional — configure if using file uploads)
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Email (Optional — configure if using email notifications)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=

# SMS (Optional)
# SMS_API_KEY=
# SMS_API_SECRET=

# Error Tracking (Optional — configure if using Sentry)
# SENTRY_DSN=
